{
  "name": "dev-engines-installer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "build": "bun run scripts/build.js",
    "test": "vitest run --coverage",
    "unit": "vitest --coverage",
    "lint": "eslint *.js src tests",
    "fix": "npm run lint -- --fix",
    "outdated": "npm outdated"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "bun": "^1.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-tjw-base": "^4.4.0",
    "eslint-config-tjw-import": "^2.0.0",
    "eslint-config-tjw-jest": "^3.0.1",
    "eslint-config-tjw-jsdoc": "^2.0.1",
    "eslint-import-resolver-vite": "^2.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "memfs": "^4.57.1",
    "vitest": "^4.1.2"
  },
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "version": "25.8.2"
      },
      {
        "name": "bun",
        "version": "1.3.11"
      }
    ],
    "packageManager": {
      "name": "npm",
      "version": "11.11.1"
    }
  }
}
